{
    "include": ["src/**/*"],
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "noImplicitAny": false,
        "strict": true,
        "declaration": true,
        "sourceMap": true
    }
}
