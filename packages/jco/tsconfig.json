{
    "include": ["src"],
    "compilerOptions": {
        "outDir": "types",
        "rootDir": "src",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowJs": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationMap": true,
        "skipLibCheck": true
    }
}
