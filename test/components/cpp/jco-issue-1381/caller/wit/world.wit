package test:jco-bug;

interface fs-provider {
    resource file {
        constructor(path: string);
        size: func() -> u64;
    }

    resource group {
        constructor(a: own<file>, b: own<file>);
        sizes: func() -> tuple<u64, u64>;
    }

    open-temp: func() -> own<file>;
    make-group: func(a: own<file>, b: own<file>) -> own<group>;
}

interface fs-consumer {
    use fs-provider.{file, group};

    transfer: func(f: own<file>) -> own<file>;
    transfer-two: func(a: own<file>, b: own<file>) -> tuple<own<file>, own<file>>;
    group-roundtrip: func(g: own<group>, seed: own<file>) -> tuple<own<group>, own<file>>;
    cascade-own: func(a: own<file>, b: own<file>, c: own<file>, d: own<file>) -> own<file>;
}

world consumer {
    include wasi:cli/imports@0.2.0;

    import fs-provider;
 
    export fs-consumer;
    export wasi:cli/run@0.2.0;
}