{
  "name": "http-server-hono-with-bindings",
  "description": "Example a Hono WebAssembly HTTP server which uses 'wasi:config/store' and 'wasi:cli/environment'",
  "private": true,
  "main": "dist/guest/component.ts",
  "type": "module",
  "scripts": {
    "gen:types": "jco guest-types wit -o generated/types",
    "build:ts": "rolldown -c rolldown.config.mjs",
    "build:component": "jco componentize -w wit -o dist/guest/component.wasm dist/guest/component.js",
    "build": "pnpm run gen:types && pnpm run build:ts && pnpm run build:component",
    "transpile": "jco transpile -o dist/transpiled dist/guest/component.wasm",
    "serve": "jco serve dist/guest/component.wasm",
    "demo": "node scripts/demo.mjs",
    "all": "pnpm run build && pnpm run demo"
  },
  "license": "MIT",
  "dependencies": {
    "@bytecodealliance/jco-std": "^0.2.0",
    "hono": "^4.12.24"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.20.0",
    "rolldown": "^1.1.0",
    "terminate": "^2.8.0",
    "typescript": "^6.0.3"
  }
}
